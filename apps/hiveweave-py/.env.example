# HiveWeave Python Backend Configuration
# Copy this file to .env and fill in your values.

# Optional: OpenCode API key (legacy seed path)
HIVEWEAVE_OPENCODE_API_KEY=sk-your-opencode-key-here

# Volcengine Ark Agent Plan (OpenAI-compatible) — primary channel
HIVEWEAVE_ARK_API_KEY=ark-your-plan-key
HIVEWEAVE_ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/plan/v3
# deepseek-v4-flash 是火山方舟 Agent/Coding Plan 的公开默认模型 ID
# （非密钥，见 volcengine.com/docs/82379）；可按需在控制台切换其他模型
HIVEWEAVE_ARK_MODEL_ID=deepseek-v4-flash

# Optional: Ark Coding Plan — second channel for rate-limit pooling
# HIVEWEAVE_ARK_CODING_API_KEY=ark-your-coding-key
# HIVEWEAVE_ARK_CODING_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
# HIVEWEAVE_ARK_CODING_MODEL_ID=deepseek-v4-flash

# Round-robin active models across agents (default true)
# HIVEWEAVE_MODEL_POOL_ENABLED=true
# HIVEWEAVE_LLM_MAX_CONCURRENT=12

# Optional: Meta DB path override (默认 apps/hiveweave-py/data/hiveweave.db)
# HIVEWEAVE_META_DB_PATH=

# Optional: API key auth (未设则开放)
# HIVEWEAVE_API_KEY=

# Optional: gstack browse.exe path (empty = auto-detect ~/.claude/skills/gstack/browse/dist/)
# HIVEWEAVE_BROWSE_BIN=C:\Users\YOU\.claude\skills\gstack\browse\dist\browse.exe

# Optional: external SKILL.md directory (browse/qa are also built-in)
# HIVEWEAVE_EXTERNAL_SKILLS_DIR=
