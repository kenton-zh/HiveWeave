# HiveWeave Server Configuration
# Copy this file to .env and fill in your values.

# Required: Open Code API key (所有 AI 请求走 Open Code 平台)
OPENCODE_API_KEY=sk-your-opencode-key-here

# Server port (default: 3200)
PORT=3200

# Optional: HTTP/HTTPS proxy for restricted network environments
# e.g. for users behind firewalls or in mainland China
# HTTPS_PROXY=http://127.0.0.1:33210
